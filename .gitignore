# Virtual environments
.venv/
.venv-nas/
venv/
env/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.pytest_cache/

# ONNX / TensorRT artifacts (large, regeneratable)
*.onnx
*.engine
*.plan

# Data — device-specific measurements, large, regeneratable
data/

# Target dataset (D1 = gate-pose, ~1.6 GB synthetic A2RL renders) — large +
# externally sourced, tracked outside git like data/. Keep the schema doc.
dataset/*
!dataset/SCHEMA.md

# Downloaded pretrained checkpoints (e.g. OFA supernet, 31 MB) — see
# supernet/download_ofa.py. Re-fetched + SHA-verified on demand, never
# tracked in git.
.cache/

# PyTorch checkpoints saved locally (e.g. state/winner_v1/*.pt)
*.pt
*.pth

# Claude AI — session memory and local settings (personal, not project config)
.claude/

# Secrets — never track credentials of any kind
*credential*
*secret*
secrets/            # Kaggle token (secrets/kaggle.json) — read by kaggle/push.sh
*.pem
.env
.env.*

# Kaggle push staging (hardlinked data + substituted metadata) — kaggle/push.sh
kaggle/_build/
# Real Jetson endpoint (host/port/user) — merged over config.yaml by
# lut/orchestrate/ssh_client.py and scripts/{setup,teardown}_jetson.sh
config.local.yaml

# Tool caches
.ruff_cache/
.mypy_cache/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temp
/tmp/

# Nested deployment/training repo (separate git project, vendored locally)
yolo-ros2-inference/

# External A2RL gate datasets dropped at the repo root (large image/label trees,
# like dataset/ — sourced + tracked outside git). Add new dated drops here.
20_jan_a2rl_WITH_SYNTH/
12dec_3jan_fused_fixed/

# YOLO/Ultralytics training outputs (weights, plots, tensorboard, results.csv)
experiments/
runs/
wandb/
*.tfevents.*

dataset.zip
.venv-cloud/

# Recovered proprietary AutoTiler blob (GAP8 toolchain) — fetched +
# SHA-verified on demand by mcu/fetch_tiler.sh, never tracked (EULA).
mcu/vendor/

# GAP8 app build trees (regenerable; written root-owned from inside the
# tfm-gap8 container, so clean them with mcu/run.sh 'rm -rf ...', not host rm).
mcu/probes/*/BUILD/

# Loss-landscape surface data (generated on GPU by figs/loss_landscape.py, pulled from
# Kaggle; the deliverable is copied into the thesis LaTeX repo, not tracked here).
figs/data/
