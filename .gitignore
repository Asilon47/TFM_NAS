# Virtual environments
.venv/
.venv-nas/
venv/
env/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.pytest_cache/

# ONNX / TensorRT artifacts (large, regeneratable)
*.onnx
*.engine
*.plan

# Data — device-specific measurements, large, regeneratable
data/

# PyTorch checkpoints saved locally (e.g. state/winner_v1/*.pt)
*.pt
*.pth

# Claude AI — session memory and local settings (personal, not project config)
.claude/

# Secrets — never track credentials of any kind
*credential*
*secret*
*.pem
.env
.env.*
# Real Jetson endpoint (host/port/user) — merged over config.yaml by
# lut/orchestrate/ssh_client.py and scripts/{setup,teardown}_jetson.sh
config.local.yaml

# Tool caches
.ruff_cache/
.mypy_cache/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temp
/tmp/
